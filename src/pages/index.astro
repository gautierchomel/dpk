---
const siteTitle = "DPK Journal";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{siteTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #f4f1ea;
        --ink: #1f1f1f;
        --accent: #0f766e;
        --card: #fffdf9;
        --line: #d8d2c6;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: "Space Grotesk", sans-serif;
        line-height: 1.5;
        color: var(--ink);
        background:
          radial-gradient(circle at 10% 10%, #fef5d7 0%, transparent 35%),
          radial-gradient(circle at 90% 15%, #d9efe8 0%, transparent 30%),
          var(--bg);
        min-height: 100vh;
      }
      .container {
        max-width: 1040px;
        margin: 0 auto;
        padding: 2rem 1.25rem 4rem;
      }
      header {
        border: 1px solid var(--line);
        background: linear-gradient(120deg, #fff, #f8f4ec);
        padding: 2.2rem;
        margin-bottom: 1.5rem;
        border-radius: 18px;
      }
      h1 {
        font-size: clamp(2rem, 5vw, 3rem);
        letter-spacing: -0.03em;
        margin-bottom: 0.35rem;
      }
      .subtitle {
        color: #4a4a4a;
      }
      .toolbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.25rem;
      }
      .toolbar a {
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
      }
      .articles {
        display: grid;
        gap: 1rem;
      }
      article {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1.3rem;
        opacity: 0;
        transform: translateY(10px);
        animation: rise 320ms ease-out forwards;
      }
      article h2 {
        font-size: 1.2rem;
        margin-bottom: 0.45rem;
      }
      article a {
        color: var(--ink);
        text-decoration: none;
      }
      article a:hover h2 {
        color: var(--accent);
      }
      .meta {
        color: #666;
        font-size: 0.9rem;
        margin-bottom: 0.55rem;
      }
      .excerpt {
        font-family: "Source Serif 4", serif;
        color: #313131;
      }
      .cover {
        width: 100%;
        max-height: 260px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid var(--line);
        margin-bottom: 0.7rem;
      }
      .empty,
      .error,
      .loading {
        background: var(--card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 1rem;
      }
      .error {
        border-left: 5px solid #b42318;
      }
      @keyframes rise {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @media (max-width: 640px) {
        .toolbar {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>{siteTitle}</h1>
        <p class="subtitle">Public articles powered by Supabase</p>
      </header>

      <div class="toolbar">
        <p>Latest published pieces</p>
        <a href="/admin">Open Editor</a>
      </div>

      <div id="loading" class="loading">Loading articles...</div>
      <div id="error" class="error" style="display:none;"></div>
      <div id="empty" class="empty" style="display:none;">No published articles yet.</div>
      <section id="articles" class="articles" aria-live="polite"></section>
    </div>

    <script type="module">
      import { supabase } from "../lib/supabaseClient";

      const articlesEl = document.getElementById("articles");
      const loadingEl = document.getElementById("loading");
      const errorEl = document.getElementById("error");
      const emptyEl = document.getElementById("empty");

      function escapeHtml(value) {
        const div = document.createElement("div");
        div.textContent = value ?? "";
        return div.innerHTML;
      }

      async function loadArticles() {
        const { data, error } = await supabase
          .from("articles")
          .select("id, title, slug, excerpt, cover_image_url, updated_at")
          .eq("published", true)
          .order("updated_at", { ascending: false });

        loadingEl.style.display = "none";

        if (error) {
          errorEl.style.display = "block";
          errorEl.innerHTML = `<strong>Could not load articles:</strong> ${escapeHtml(error.message)}`;
          return;
        }

        if (!data || data.length === 0) {
          emptyEl.style.display = "block";
          return;
        }

        articlesEl.innerHTML = data
          .map(
            (item, index) => `
              <article style="animation-delay: ${index * 60}ms;">
                ${item.cover_image_url ? `<img class="cover" src="${escapeHtml(item.cover_image_url)}" alt="${escapeHtml(item.title)}" loading="lazy" />` : ""}
                <a href="/articles/${encodeURIComponent(item.slug)}">
                  <h2>${escapeHtml(item.title)}</h2>
                </a>
                <p class="meta">Updated ${new Date(item.updated_at).toLocaleDateString()}</p>
                <p class="excerpt">${escapeHtml(item.excerpt || "No excerpt yet.")}</p>
              </article>
            `
          )
          .join("");
      }

      loadArticles();
    </script>
  </body>
</html>
