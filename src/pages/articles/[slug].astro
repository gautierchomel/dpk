---
import { createClient } from "@supabase/supabase-js";

const slug = Astro.params.slug;
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

export async function getStaticPaths() {
  const url = import.meta.env.PUBLIC_SUPABASE_URL;
  const anon = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  if (!url || !anon) {
    return [];
  }

  const supabase = createClient(url, anon);
  const { data, error } = await supabase
    .from("articles")
    .select("slug")
    .eq("published", true);

  if (error || !data) {
    return [];
  }

  return data
    .filter((item) => item.slug)
    .map((item) => ({
      params: { slug: item.slug },
    }));
}

let article = null;
let loadError = null;

if (!supabaseUrl || !supabaseAnonKey) {
  loadError = "Supabase environment variables are missing.";
} else if (!slug) {
  loadError = "Article slug is missing.";
} else {
  const supabase = createClient(supabaseUrl, supabaseAnonKey);
  const { data, error } = await supabase
    .from("articles")
    .select("title, body, excerpt, updated_at, cover_image_url")
    .eq("slug", slug)
    .eq("published", true)
    .maybeSingle();

  if (error) {
    loadError = error.message;
  } else {
    article = data;
  }
}

if (!article) {
  Astro.response.status = 404;
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{article?.title || "Not Found"} | DPK Journal</title>
    <style>
      body {
        margin: 0;
        font-family: "Source Serif 4", Georgia, serif;
        background: #f8f5ee;
        color: #1d1d1d;
      }
      main {
        max-width: 820px;
        margin: 2rem auto;
        padding: 0 1rem 3rem;
      }
      a {
        color: #0f766e;
        text-decoration: none;
      }
      h1 {
        font-family: "Space Grotesk", sans-serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        margin-bottom: 0.4rem;
      }
      .meta {
        color: #666;
        margin-bottom: 1.4rem;
      }
      .body {
        line-height: 1.75;
        white-space: pre-wrap;
      }
      .cover {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        border-radius: 12px;
        margin: 0.4rem 0 1rem;
      }
      .error {
        background: #fff;
        border: 1px solid #d8d2c6;
        border-radius: 12px;
        padding: 1rem;
      }
    </style>
  </head>
  <body>
    <main>
      <p><a href="/">← Back to all articles</a></p>
      {
        article ? (
          <article>
            <h1>{article.title}</h1>
            <p class="meta">Updated {new Date(article.updated_at).toLocaleDateString()}</p>
            {article.cover_image_url && <img class="cover" src={article.cover_image_url} alt={article.title} />}
            <p class="body">{article.body || article.excerpt || "No content yet."}</p>
          </article>
        ) : (
          <section class="error">
            <h1>Article not found</h1>
            <p>{loadError || "This article is missing or not published."}</p>
          </section>
        )
      }
    </main>
  </body>
</html>
