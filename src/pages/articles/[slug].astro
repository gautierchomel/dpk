---
import { fetchStrapiArticleBySlug, fetchStrapiArticles } from "../../lib/strapi";

const { slug } = Astro.params;
let selectedArticle = null;
let loadError = "";

export async function getStaticPaths() {
  try {
    const articles = await fetchStrapiArticles();
    return articles.map((article) => ({
      params: { slug: article.slug },
      props: { article },
    }));
  } catch {
    return [];
  }
}

if (Astro.props.article) {
  selectedArticle = Astro.props.article;
} else if (slug) {
  try {
    selectedArticle = await fetchStrapiArticleBySlug(slug);
  } catch (e) {
    loadError = e instanceof Error ? e.message : "Failed to load article from Strapi.";
  }
}

if (!selectedArticle) {
  Astro.response.status = 404;
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{selectedArticle?.title || "Not Found"} | DPK</title>
    <style>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        line-height: 1.6;
        color: #1d1d1d;
        background: #f7f7f7;
      }
      main {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }
      .card {
        background: #fff;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      }
      a {
        color: #0066cc;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .meta {
        color: #666;
        margin-bottom: 1rem;
      }
      .cover {
        width: 100%;
        max-height: 420px;
        object-fit: cover;
        border-radius: 8px;
        margin-bottom: 1rem;
      }
      .body {
        white-space: pre-wrap;
      }
      .body :global(p) {
        margin: 0.8rem 0;
      }
      .error {
        background: #fee;
        color: #c33;
        padding: 1rem;
        border-radius: 4px;
        border-left: 4px solid #c33;
      }
    </style>
  </head>
  <body>
    <main>
      <p><a href="/"><- Back to all articles</a></p>
      {
        selectedArticle ? (
          <article class="card">
            <h1>{selectedArticle.title}</h1>
            <p class="meta">
              Published {new Date(selectedArticle.publishedAt || selectedArticle.createdAt).toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
              {selectedArticle.authorName && <> · By {selectedArticle.authorName}</>}
              {selectedArticle.categoryName && <> · {selectedArticle.categoryName}</>}
            </p>
            {selectedArticle.coverUrl && <img class="cover" src={selectedArticle.coverUrl} alt={selectedArticle.title} />}
            {
              selectedArticle.body ? (
                <div class="body" set:html={selectedArticle.body} />
              ) : (
                <p class="body">{selectedArticle.excerpt || "No content available."}</p>
              )
            }
          </article>
        ) : (
          <section class="error">
            <h1>Article not found</h1>
            <p>{loadError || "No article matches this URL."}</p>
          </section>
        )
      }
    </main>
  </body>
</html>
