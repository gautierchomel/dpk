---
import AposArea from "@apostrophecms/apostrophe-astro/components/AposArea.astro";

const { piece } = Astro.props.aposData;
---

<article class="wrap">
  <p><a href="/articles">Back to articles</a></p>
  <h1>{piece?.title}</h1>
  {piece?.excerpt && <p class="excerpt">{piece.excerpt}</p>}
  <AposArea area={piece?.body} />
</article>

<style>
  .wrap {
    max-width: 64rem;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .excerpt {
    color: #475569;
  }
</style>
