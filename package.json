{
  "name": "dpk",
  "version": "1.0.0",
  "description": "Astro static site connected to a Strapi backend",
  "scripts": {
    "dev": "astro dev",
    "dev:strapi": "npm --prefix dpk run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:strapi\"",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gautierchomel/dpk.git"
  },
  "keywords": [
    "astro",
    "strapi",
    "headless-cms"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/gautierchomel/dpk/issues"
  },
  "homepage": "https://github.com/gautierchomel/dpk#readme",
  "dependencies": {
    "astro": "^4.16.19"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
